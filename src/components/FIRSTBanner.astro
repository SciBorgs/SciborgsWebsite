---
const { award_name, award_event } = Astro.props;
---

<div class="banner">
  <img src="https://www.thebluealliance.com/images/first_icon.svg" />
  <span class="awardName">{award_name}</span>
  <span class="awardEvent">{award_event}</span>
</div>

<style>
  .banner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    align-self: center;
    gap: 1.5rem;
    width: 140px;
    height: 170px;
    margin-bottom: 1.625rem;
    padding: 1rem;
    font-family: Roboto;
    text-transform: uppercase;
    background: rgb(15 75 203);

    img {
      width: 75px;
    }
  }

  .banner::after {
    position: absolute;
    top: 100%;
    left: 0;
    display: block;
    border-color: rgb(15 75 203) rgb(15 75 203) transparent;
    border-style: solid;
    border-width: 5px 70px 20px;
    content: "";
    filter: drop-shadow(rgb(0 0 0 / 10%) 0 5px 5px);
  }

  .awardName {
    font-size: var(--text-sm);
    font-style: italic;
  }

  .awardEvent {
    font-size: var(--text-xs);
    text-align: center;
  }
</style>