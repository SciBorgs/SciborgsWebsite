---
import { school_desc } from "../../public/info.json";
---

<div class="container">
  <div class="infoSection">
    <img src="bxsci.webp" />
    <h1>Our School</h1>
    <p>{school_desc}</p>
  </div>
</div>

<style>
  img {
    width: 100%;
    height: auto;
    border-radius: 0.25rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    width: 80%;
    margin-inline: auto;

    h1, p {
      text-align: center;
      margin-block: 1.25rem;
    }

    p {
      font-size: var(--text-sm);
      margin-block: 0.5rem;
    }
  }

  .infoSection {
    display: grid;
    grid-template-rows: repeat(3, auto);

    h1 {
      grid-row: 1 / 2;
    }
  }

  @media (width >= 48rem) {
    img {
      grid-row: 1 / 3;
    }

    .infoSection {
      gap: 1rem;
      grid-template-columns: auto auto;
      grid-template-rows: auto 1fr;

      h1 {
        text-align: left;
      }

      p {
        grid-row: 2 / 3;
      }
    }

    .infoContainer {
      display: flex;
      flex-direction: column;
    }
  }
</style>
