---
import { school_desc } from "../../public/info.json";
---

<div class="container">
  <div class="infoSection">
    <img src="bxsci.webp" />
    <h1 class="header schoolHeader">Our School</h1>
    <p class="schoolDesc" set:html={school_desc} />
  </div>
</div>

<style>
  img {
    width: 100%;
    height: auto;
    border-radius: 0.25rem;
  }

  .container {
    padding: 0.5rem 1rem;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .schoolHeader {
    text-align: center;
    grid-row: 1 / 2;
  }

  .schoolDesc {
    font-size: var(--text-lg);
    text-align: center;
    margin-block: 0;
  }

  .infoSection {
    display: grid;
    gap: 0.5rem;
    grid-template-rows: repeat(3, auto);
  }

  @media (width >= 48rem) {
    img {
      grid-row: 1 / 3;
    }

    .container {
      padding: 1rem 5rem;
    }

    .infoSection {
      grid-template-columns: auto auto;
      grid-template-rows: auto 1fr;
    }

    .schoolHeader {
      text-align: left;
      margin-left: 0.5rem;
    }

    .schoolDesc {
      margin-left: 0.5rem;
      text-align: left;
      font-size: var(--text-2xl);
      grid-row: 2 / 3;
    }
  }
</style>
