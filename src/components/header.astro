---
import { Icon } from "astro-icon/components";

const pages = [
  { name: "Sponsors", href: "/sponsors" },
  { name: "Donate", href: "/donate" },
];

const path = Astro.url.pathname;
---

<div class="container">
  <div id="navBar">
    <a data-tap="1.1" href="/">
      <img class="logo" src="sciborgs.webp" />
    </a>
    <div class="tabs">
      {
        pages.map((page) => (
          <a class="link tab" data-tap="1.2" href={page.href}>
            <h1>{page.name}</h1>
          </a>
        ))
      } 
    </div>
    <div data-tap="1.3" class="mobileIcon" onclick="appearTab()">
      <Icon id="icon" name="mdi:menu" />
    </div>
  </div>
  <div id="mobileTab">
    <div class="section">
      {
        pages.map((page) => (
          <a class="link" href={page.href}>
            <Icon
              id="icon"
              name="mdi:chevron-double-right"
              style={{ visibility: path == page.href ? "visible" : "hidden" }}
            />
            <h1 data-tap="1.3">{page.name}</h1>
          </a>
        ))
      }
    </div>
    <div class="outerSection" onclick="appearTab()"></div>
  </div>
</div>

<style lang="scss">
  .container {
    position: fixed;
    z-index: 101;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
  }

  #navBar {
    position: fixed;
    top: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 6rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(to bottom, #a3854d, rgb(255 0 0 / 0%));
    transition: transform 1s ease;
    transform: translateY(-10rem);

    &.activeMobile {
      transform: translateY(0);
    }
  }

  .logo {
    display: block;
    width: auto;
    height: 4rem;
    filter: drop-shadow(3px 3px 5px rgb(0 0 0 / 50%));
  }

  .tabs {
    display: none;
  }

  .tab {
    background-color: var(--color-bg);
  }

  .mobileIcon {
    display: inline-flex;
    padding: 0.25rem;
    border: 2px var(--white-but-not) solid;
    border-radius: 0.25rem;
    filter: drop-shadow(3px 3px 5px rgb(0 0 0 / 50%));
    pointer-events: auto;
  }

  #icon {
    width: auto;
    height: 2rem;
    color: var(--white-but-not);
  }

  #mobileTab {
    position: fixed;
    z-index: 102;
    display: flex;
    flex-direction: row-reverse;
    width: 100vw;
    height: 100vh;
    background-color: transparent;
    transition:
      transform 500ms ease-in-out,
      background-color 350ms ease-in-out;
    pointer-events: auto;
    transform: translateX(100%);

    &.appearTab {
      visibility: visible;
      background-color: rgb(0 0 0 / 50%);
      transform: translateX(0);
    }
  }

  .section {
    width: 60%;
    background-color: #1b253c;
    border-radius: 0.5rem;
  }

  .outerSection {
    flex-grow: 1;
  }

  .link {
    display: flex;
    flex-direction: row;
    align-items: center;
    pointer-events: auto;
  }

  @media (width >= 48rem) {
    #mobile {
      display: none;
    }

    .mobileIcon {
      display: none;
    }

    .tabs {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
    }

    .link {
      padding: 0.25rem;
      border: 1px var(--white-but-not) solid;
      border-radius: 0.125rem;
    }
  }
</style>

<script is:inline>
  function preventScroll(e) {
    e.preventDefault();
  }

  let currContain = false;
  function appearTab() {
    const isDesktop = window.innerWidth >= 768;
    if (isDesktop) return;

    const tab = document.getElementById("mobileTab");
    currContain = !currContain;
    if (currContain) {
      window.addEventListener("touchmove", preventScroll, { passive: false });
      window.addEventListener("wheel", preventScroll, { passive: false });
      tab.classList.add("appearTab");
    } else {
      window.removeEventListener("touchmove", preventScroll);
      window.removeEventListener("wheel", preventScroll);
      tab.classList.remove("appearTab");
    }
  }
</script>
