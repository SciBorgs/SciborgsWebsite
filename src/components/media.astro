---
import { YouTube } from "astro-embed";
import { getLatestYoutubeVideo } from "../lib/youtube";

const video = await getLatestYoutubeVideo(import.meta.env.YOUTUBE_ID);

const embedCode = `
<blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/reel/REEL_ID/" data-instgrm-version="14"></blockquote>
<script async src="//www.instagram.com/embed.js"></script>
`;
---

<div class="container">
  <div class="inner">
    <div class="mediaHeader">
      <h1 class="header">Media</h1>
      <p>Latest Content From Our Socials</p>
    </div>

    <div class="socials">
      <div class="socialContainer">
        <h2>YouTube</h2>
        {
          video ? (
            <YouTube class="youtube" id={video.videoId} title={video.title} />
          ) : (
            <p>No video available</p>
          )
        }
      </div>

      <div class="socialContainer">
        <h2>Instagram</h2>
        <iframe
          src="https://www.instagram.com/reel/DFi2rKrJVMp/embed"
          id="instagram"
          class="instagram-media"
          scrolling="no"
          allowtransparency="true"
        >
        </iframe>
      </div>
    </div>
  </div>
  <script async src="https://www.instagram.com/embed.js"></script>
</div>

<style lang="scss">
  .container {
    width: 100%;
  }

  .inner {
    padding: 1.5rem;
    background: var(--background);
  }

  .mediaHeader {
    margin-bottom: 1rem;
    text-align: center;

    p {
      font-size: var(--text-md);
      opacity: 0.75;
    }
  }

  .socials {
    display: grid;
    justify-content: center;
    align-items: start;
    gap: 2rem;
    grid-template-rows: auto 1fr;
  }

  .socialContainer {
    display: flex;
    overflow: hidden;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 24rem !important;
    max-width: 720px;
    padding: 1rem;
    background: var(--background);
    border: 1px solid var(--white-but-not);
    border-radius: 1rem;
    box-shadow: 0 4px 16px rgb(0 0 0 / 25%);

    h2 {
      margin-block: 0;
    }
  }

  .youtube {
    width: 100%;
    border-radius: 0.75rem;
    aspect-ratio: 16 / 9;
  }

  @media (width >= 48rem) {
    .socials {
      display: flex;
      justify-content: center;
    }
  }
</style>
