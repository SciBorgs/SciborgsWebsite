---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import sponsors from "../../public/sponsors.json";

const emails = [
  "firstinitiallastname@example.com",
  "firstinitiallastname@example.com",
];

const types = ["0", "1", "2", "3", "4"];
const typeNames = ["Byte", "Kilobyte", "Megabyte", "Gigabyte", "Terabyte"];
const colors = [
  "--color-orange",
  "--color-brown",
  "--color-gray",
  "--color-lime",
  "--color-green",
];

const sponsorGroups = types.map((type, index) => ({
  id: type as unknown as number,
  name: typeNames[index],
  sponsors: sponsors.filter((sponsor) => sponsor.type === type),
}));
---

<Layout>
  <div id="donateContainer">
    <h1 class="donateHeader header">Donate</h1>
    <img class="sponsorTiers" src="/sponsorTiers.png" />
    <div class="donateInfo">
      <p class="donateDesc">
        Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus
        ex sapien vitae pellentesque sem placerat. In id cursus mi pretium
        tellus duis convallis. Tempus leo eu aenean sed diam urna tempor.
        Pulvinar vivamus fringilla lacus nec metus bibendum egestas. Iaculis
        massa nisl malesuada lacinia integer nunc posuere. Ut hendrerit semper
        vel class aptent taciti sociosqu. Ad litora torquent per conubia nostra
        inceptos himenaeos.
      </p>
      <h3 class="smHeader" style="text-align: center;">Consider donating!</h3>
      <div class="emailContainer">
        <div id="toggleEmails">
          <Icon id="emailSelector" name="mdi:menu-right" />
          <p>Show Emails</p>
        </div>
        <div id="emailsContainer">
          <div style="padding: 0.5rem;">
            <h3 class="smHeader">Sciborgs Contact</h3>
            <p>{emails[0]}</p>
            <h3 class="smHeader">Sponsorships Lead</h3>
            <p class="miniInfo">(quicker response time)</p>
            <p>{emails[1]}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- -->
  <div id="divider"></div>

  <div id="sponsorsContainer">
    <h1 class="header">Sponsors</h1>
    <div class="tiersContainer">
      {
        sponsorGroups.map((group) =>
          group.sponsors.length > 0 ? (
            <div class="tierContainer">
              <h1
                class="tierHeader"
                style={`background-color: var(${colors[group.id]})`}
              >
                {group.name}
              </h1>
              <div class="sponsorContainer">
                {group.sponsors.map((sponsor) => (
                  <a href={sponsor.href}>
                    <Icon name={sponsor.src} class="sponsorLogo" />
                  </a>
                ))}
              </div>
            </div>
          ) : null,
        )
      }
    </div>
  </div>
</Layout>

<style>
  #donateContainer {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1rem;
    padding-top: 5rem;
  }

  .sponsorTiers {
    width: 100%;
    height: auto;
    border: 1px black solid;
    border-radius: 0.25rem;
    filter: drop-shadow(3px 3px 5px rgb(0 0 0));
  }

  .donateInfo {
    width: auto;
  }

  .donateDesc {
    font-size: var(--text-sm);
  }

  .emailContainer {
    display: flex;
    flex-direction: column;
    width: 100%;
    outline: 1px solid var(--white-but-not);
    outline-offset: -1px;
  }

  #toggleEmails {
    display: flex;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: 0.5rem;
    cursor: pointer;
  }

  #emailSelector {
    transition: rotate 350ms ease;
    rotate: 0deg;
  }

  #emailSelector.activeIcon {
    rotate: 90deg;
  }

  #emailsContainer {
    overflow: hidden;
    max-height: 0;
    transition: max-height 350ms ease-in-out;
    border-top: 1px solid white;
  }

  #emailsContainer.emailExpand {
    max-height: var(--max-height);
  }

  .miniInfo {
    font-size: var(--text-xs);
    color: rgb(255 255 255 / 25%);
  }

  #sponsorsContainer {
    position: relative;
    overflow: hidden visible;
    padding: 0.5rem 1rem;
  }

  .tiersContainer {
    display: flex;
    flex-direction: column;
    width: 100%;
    align-items: center;
    gap: 1.5rem;
  }

  #divider {
    width: 90%;
    border-bottom: 2px var(--white-but-not) solid;
    margin-block: 1.5rem;
    margin-inline: auto;
  }

  .tierContainer {
    overflow: hidden;
    background-color: var(--color-bg);
    border: 2px var(--white-but-not) solid;
    border-radius: 1.5rem;
    width: 65%;
  }

  .tierHeader {
    font-size: var(--text-3xl);
    text-align: center;
    color: white;
    border-bottom: 2px var(--white-but-not) solid;
    margin-block: 0;
    padding-block: 1rem;
  }

  .sponsorContainer {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    padding: 1.25rem 2rem;
  }

  .sponsor {
    position: relative;
  }

  .sponsorLogo {
    width: 100%;
    height: auto;
    color: var(--color-sciborgs);
    filter: drop-shadow(3px 3px 5px rgb(0 0 0 / 50%));
  }

  @media (width >= 48rem) {
    #donateContainer {
      display: grid;
      gap: 1rem;
      padding: 0.5rem 2.5rem;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto 1fr;
      padding-top: 2.5rem;
    }

    .donateHeader {
      grid-column: 1 / 3;
    }

    .donateInfo {
      width: 32rem;
    }

    .donateDesc {
      font-size: var(--text-lg);
      grid-column: 2 / 3;
    }

    .emailContainer {
      grid-column: 2 / 3;
    }

    .sponsorContainer {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      place-items: center center;
    }

    .sponsorHeader {
      font-size: var(--text-7xl);
      grid-column: 1 / 3;
    }

    .tiers {
      grid-column: 1 / 2;
    }

    .sponsorLogo {
      width: 16rem;
    }

    @media (width >= 32rem) {
      .sponsorContainer {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  }
</style>

<script is:inline>
  let showEmail = false;

  const toggle = document.getElementById("toggleEmails");
  const container = document.getElementById("emailsContainer");
  const icon = document.getElementById("emailSelector");

  toggle.addEventListener("click", () => {
    showEmail = !showEmail;

    container.classList.toggle("emailExpand", showEmail);
    icon.classList.toggle("activeIcon", showEmail);
  });
  container.style.setProperty("--max-height", `${container.scrollHeight}px`);
</script>
