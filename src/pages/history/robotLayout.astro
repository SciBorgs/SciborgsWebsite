---
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import robots from "../../history.json";

const sortedSeasons = robots.sort((a, b) => b.year - a.year);
---

<Layout>
  <div class="container">
    <div id="navBar">
      <div id="toggleSeasons" onclick="appearSeasons()">
        <Icon id="indicator" name="mdi:menu-right" />
        <h1>Team History</h1>
      </div>
      <div id="seasonsContainer">
        <div class="divider"></div>
        {
          sortedSeasons.map((season, i) => {
            const delay = i * 0.0325;
            return (
              <a href={"/history/" + season.year}>
                <p class="seasonHeader" style={`--delay: ${delay}s`}>
                  {season.year + ": " + season.seasonName}
                </p>
              </a>
            );
          })
        }
      </div>
      <div class="divider"></div>
    </div>
    <slot />
  </div>
</Layout>

<style>
  img {
    width: 6rem;
    height: 6rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    padding: 3rem 2rem;
    padding-top: 5rem;
  }

  #toggleSeasons {
    display: flex;
    flex-direction: row-reverse;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: 0.5rem;
    cursor: pointer;
  }

  #indicator {
    font-size: 1.5rem;
    transition: rotate 350ms ease;
    rotate: 180deg;
  }

  #indicator.activeIcon {
    rotate: 90deg;
  }

  #seasonsContainer {
    max-height: 0;
    transition: max-height 650ms ease;
    overflow: hidden;
  }

  #seasonsContainer.expand {
    max-height: var(--max-height);
  }

  .seasonHeader {
    opacity: 0;
    padding: 0.5rem;
    text-align: left;
    background-color: var(--color-yellow);
    border-radius: 0.25rem;
    transition: opacity 650ms ease;
  }

  .animateHeader {
    transition: opacity 200ms ease;
    transition-delay: var(--delay);
    opacity: 1;
  }

  .divider {
    margin: 0.75rem 1rem;
    border-top: 1px var(--white-but-not) solid;
  }

  .yearHeader {
    display: flex;
    width: 8rem;
    height: 3rem;
    background-color: red;
    text-align: center;
    justify-content: center;
    align-items: center;
  }

  @media (width >= 48rem) {
  }
</style>

<script is:inline>
  let showSeasons = false;
  let isAnimating = false;
  const container = document.getElementById("seasonsContainer");

  function appearSeasons() {
    if (isAnimating) return;
    const icon = document.getElementById("indicator");
    const seasonHeaders = document.querySelectorAll(".seasonHeader");

    isAnimating = true;
    showSeasons = !showSeasons;

    seasonHeaders.forEach(
      (header) => header.classList.toggle("animateHeader"),
      showSeasons,
    );
    container.classList.toggle("expand", showSeasons);
    icon.classList.toggle("activeIcon", showSeasons);

    setTimeout(
      () => {
        isAnimating = false;
      },
      (seasonHeaders.length - 1) * 32.5,
    );
  }

  container.style.setProperty("--max-height", `${container.scrollHeight}px`);
</script>
