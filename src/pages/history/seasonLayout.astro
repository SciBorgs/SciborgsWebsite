---
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import Seasons from "../../history.json";

const sortedSeasons = Seasons.sort((a, b) => b.year - a.year);

const { year } = Astro.params;
const foundYear = Number(year);
const season = Seasons.filter((season) => {
  return season.year == foundYear;
});
const selSeason = season[0];

const highestYear = Seasons[sortedSeasons.length - 1].year;
const lowestYear = Seasons[0].year;
---

<Layout>
  <div class="container">
    <div id="mobileBar">
      <div id="toggleSeasons" onclick="appearSeasons()">
        <Icon id="indicator" name="mdi:menu-right" />
        <h1>Team History</h1>
      </div>
      <div id="seasonsContainer">
        <div class="divider"></div>
        {
          sortedSeasons.map((season, i) => {
            const delay = i * 0.0325;
            return (
              <a
                href={"/history/" + season.year}
                class="seasonHeader"
                style={`--delay: ${delay}s`}
              >
                <p>{season.year + " -  " + season.seasonName}</p>
              </a>
            );
          })
        }
      </div>
      <div class="divider"></div>
    </div>
    <div id="seasonNav" class="safeView">
      <div class="infoContainer">
        <div>
          <h1>{selSeason.seasonName}</h1>
          <img class="FirstLogo" src={selSeason.src} />
        </div>
        <div class="arrowContainer">
          {
            foundYear != highestYear ? (
              <a
                href={`/history/${foundYear - 1}`}
                data-tap="1.2"
                class="arrow"
              >
                <Icon name="mdi:arrow-left" />
              </a>
            ) : (
              <a href={`/history/${lowestYear}`} data-tap="1.2" class="arrow">
                <Icon name="mdi:arrow-left" />
              </a>
            )
          }

          {
            foundYear != lowestYear ? (
              <a
                href={`/history/${foundYear + 1}`}
                data-tap="1.2"
                class="arrow"
              >
                <Icon name="mdi:arrow-right" />
              </a>
            ) : (
              <a href={`/history/${highestYear}`} data-tap="1.2" class="arrow">
                <Icon name="mdi:arrow-right" />
              </a>
            )
          }
        </div>
      </div>
    </div>
    <div class="innerContainer">
      <slot />
    </div>
  </div>
</Layout>

<style>
  img {
    width: 6rem;
    height: 6rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    padding: 3rem 2rem;
    padding-top: 5rem;
  }

  #toggleSeasons {
    display: flex;
    flex-direction: row-reverse;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: 0.5rem;
    cursor: pointer;
  }

  #indicator {
    font-size: 1.5rem;
    transition: rotate 350ms ease;
    rotate: 180deg;
  }

  #indicator.activeIcon {
    rotate: 90deg;
  }

  #seasonsContainer {
    overflow: hidden;
    max-height: 0;
    transition: max-height 650ms ease;
  }

  #seasonsContainer.expand {
    max-height: var(--max-height);
  }

  .seasonHeader {
    opacity: 0;
    transition: opacity 650ms ease;

    p {
      padding: 0.5rem;
      text-align: left;
      background-color: var(--color-green);
      border-radius: 0.25rem;
      margin-block: 0.25rem;
    }
  }

  .animateHeader {
    opacity: 1;
    transition: opacity 200ms ease;
    transition-delay: var(--delay);
  }

  .divider {
    margin: 0.75rem 1rem;
    border-top: 1px var(--white-but-not) solid;
  }

  #seasonNav {
    display: none;
  }

  .innerContainer {
    display: flex;
    flex-grow: 1;
    justify-content: center;
  }

  @keyframes appear {
    to {
      opacity: 1;
    }
  }

  @media (width >= 48rem) {
    .container {
      display: flex;
      flex-direction: row;
      padding: 0;
      height: 100vh;
    }

    #mobileBar {
      display: none;
    }

    #seasonNav {
      display: flex;
      flex-direction: column;
      width: 40%;
      height: 100%;
      border-radius: 0rem 1.5rem 1.5rem 0rem;
      background-color: var(--color-green);
      padding: 5rem 2rem;
      justify-content: center;
      gap: 1rem;
    }

    .infoContainer {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 50%;
    }

    .FirstLogo {
      flex-grow: 1;
      width: 50%;
      height: auto;
    }

    .arrowContainer {
      display: flex;
      gap: 1rem;
    }

    .arrow {
      display: flex;
      border-radius: 0.5rem;
      border: 2px var(--white-but-not) solid;
      padding: 0.5rem;

      svg {
        font-size: var(--text-2xl);
      }
    }

    #navBar::-webkit-scrollbar {
      display: none;
    }

    .seasonHeader {
      padding: 0;
      border-radius: 0;
      opacity: 1;
      margin-block: 0;
    }
  }
</style>

<script is:inline>
  let showSeasons = false;
  let isAnimating = false;

  function appearSeasons() {
    if (isAnimating) return;
    const seasonsContainer = document.getElementById("seasonsContainer");
    const icon = document.getElementById("indicator");
    const seasonHeaders = document.querySelectorAll(".seasonHeader");

    isAnimating = true;
    showSeasons = !showSeasons;

    seasonHeaders.forEach((header) =>
      header.classList.toggle("animateHeader", showSeasons),
    );
    seasonsContainer?.classList.toggle("expand", showSeasons);
    icon?.classList.toggle("activeIcon", showSeasons);

    setTimeout(
      () => {
        isAnimating = false;
      },
      (seasonHeaders.length - 1) * 32.5,
    );
  }

  function setMaxSeasons() {
    const seasonsContainer = document.getElementById("seasonsContainer");
    isAnimating = false;
    seasonsContainer?.style.setProperty(
      "--max-height",
      `${seasonsContainer.scrollHeight}px`,
    );
  }

  document.addEventListener("DOMContentLoaded", setMaxSeasons);
  document.addEventListener("astro:page-load", setMaxSeasons);
</script>
