---
import Layout from "../layouts/Layout.astro";
import Team from "../components/team.astro";
import Media from "../components/media.astro";
import About from "../components/about.astro";
import SponsorView from "../components/sponsorView.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <Team />
  <About />
  <SponsorView fadeThrough />
  <a data-tap="1.1" class="considerDonating" href="/donate"
    >Consider Donating!<Icon name="mdi:arrow-top-right" /></a
  >
  <Media />
</Layout>

<style>
  .considerDonating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    width: fit-content;
    padding: 0.5rem;
    font-size: var(--text-xl);
    background-color: var(--color-bxsci);
    border-radius: 0.25rem;
    margin-inline: auto;
  }
</style>
