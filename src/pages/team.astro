---
import Socials from "../components/socials.astro";
---

<div class="container">
  <div>
    <img class="logo" src="sciborgs.webp" />
    <h1 class="header">FRC Team 1155</h1>
    <Socials />
  </div>

  <div id="mobile"></div>
</div>

<style>
  .container {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 0.5rem 1rem;
    background: #a3854d;
    background: linear-gradient(
      180deg,
      rgb(163 133 77 / 100%) 0%,
      rgb(17 24 39 / 100%) 100%
    );
    background-color: var(--color-black);
  }

  .logo {
    display: block;
    width: 15rem;
    height: auto;
    animation: appear 1.5s ease forwards;
  }

  .header {
    font-size: var(--text-2xl);
    text-align: center;
  }

  #mobile {
    position: absolute;
    top: 0;
    width: 100%;
    height: 10rem;
    background-color: red;
  }

  @keyframes appear {
    from {
      opacity: 0;
      transform: translateY(2rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (width >= 48rem) {
    .logo {
      width: 50rem;
    }

    .header {
      font-size: var(--text-3xl);
      text-align: left;
    }

    #mobile {
      visibility: hidden;
      height: 0;
    }
  }
</style>

<script>
  window.addEventListener("scroll", () => {
    console.log(window.scrollY);
  });
</script>
