---
import Socials from "../components/socials.astro";
---

<div class="container">
  <div>
    <img class="logo" src="sciborgs.webp" />
    <h1 class="header">FRC Team 1155</h1>
    <Socials />
  </div>
</div>

<style>
  .container {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 0.5rem 1rem;
    background-color: var(--color-black);
    background: #a3854d;
    background: linear-gradient(
      180deg,
      rgba(163, 133, 77, 1) 0%,
      rgba(17, 24, 39, 1) 100%
    );
  }

  .logo {
    display: block;
    width: 15rem;
    height: auto;
    animation: appear 1.5s ease forwards;
  }

  .header {
    font-size: var(--text-2xl);
    text-align: center;
  }

  @keyframes appear {
    from {
      opacity: 0;
      transform: translateY(2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 48rem) {
    .logo {
      width: 50rem;
    }

    .header {
      font-size: var(--text-3xl);
      text-align: left;
    }
  }
</style>
